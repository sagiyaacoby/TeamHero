[
  {
    "id": "playwright",
    "name": "Playwright Browser",
    "description": "Control Chrome to browse, click, fill forms, screenshot, and record browser sessions as video",
    "icon": "\ud83c\udf10",
    "type": "mcp",
    "packages": ["@playwright/mcp"],
    "mcpConfig": {
      "command": "npx",
      "args": ["@playwright/mcp", "--save-video=1280x720"]
    }
  },
  {
    "id": "screen-recorder",
    "name": "Screen Recorder",
    "description": "Record desktop screen or specific windows as MP4 videos using ffmpeg",
    "icon": "\ud83c\udfac",
    "type": "cli",
    "packages": [],
    "systemDeps": ["ffmpeg"],
    "scripts": {
      "start": "node data/skills/screen-recorder/record.js start",
      "stop": "node data/skills/screen-recorder/record.js stop",
      "status": "node data/skills/screen-recorder/record.js status"
    }
  },
  {
    "id": "trello",
    "name": "Trello",
    "description": "Manage Trello boards, lists, and cards. Read, create, update, and move cards. Includes intelligent task analysis with complexity scoring and status-to-list mapping.",
    "icon": "\ud83d\udccb",
    "type": "mcp",
    "packages": [],
    "gitRepo": "https://github.com/MagnusNilsson/trello-mcp-server.git",
    "buildCmd": "npm install && npm run build",
    "mcpConfig": {
      "command": "node",
      "args": ["data/skills/trello/build/index.js"],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_API_TOKEN": "${TRELLO_API_TOKEN}",
        "DEFAULT_TRELLO_BOARD_ID": "${TRELLO_BOARD_ID}"
      }
    },
    "settings": [
      { "key": "TRELLO_API_KEY", "label": "Trello API Key", "type": "secret", "required": true, "help": "Get your API key from https://trello.com/power-ups/admin" },
      { "key": "TRELLO_API_TOKEN", "label": "Trello API Token", "type": "secret", "required": true, "help": "Generate a token at https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY" },
      { "key": "TRELLO_BOARD_ID", "label": "Default Board ID", "type": "text", "required": false, "help": "Optional. The default Trello board ID to operate on." }
    ]
  },
  {
    "id": "remotion",
    "name": "Remotion Video",
    "description": "Create and render videos programmatically using React components. Build intros, demos, social clips, and promotional videos with code.",
    "icon": "\ud83c\udfa5",
    "type": "cli",
    "packages": ["remotion", "@remotion/cli", "@remotion/bundler", "@remotion/renderer"],
    "scripts": {
      "render": "npx remotion render",
      "preview": "npx remotion preview",
      "status": "npx remotion --version"
    },
    "docs": "https://www.remotion.dev/docs"
  }
]
